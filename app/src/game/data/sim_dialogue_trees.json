{
  "version": "1.1",
  "game": "Wilderfolk Sim",
  "dialogue_trees": [
    {
      "id": "dt_rock",
      "category": "work",
      "speakers": [
        "npc_laborer",
        "npc_bystander"
      ],
      "lines": [
        {
          "speaker": "npc_laborer",
          "text": "I've been carrying this rock for 3 hours. I don't know where to put it."
        },
        {
          "speaker": "npc_bystander",
          "text": "Have you tried... setting it down?"
        },
        {
          "speaker": "npc_laborer",
          "text": "I am one with the rock now. Do not interrupt our journey."
        }
      ]
    },
    {
      "id": "dt_diagonal",
      "category": "work",
      "speakers": [
        "npc_farmer",
        "npc_veteran"
      ],
      "lines": [
        {
          "speaker": "npc_farmer",
          "text": "Just watched a guy harvest an entire field by walking diagonally through it."
        },
        {
          "speaker": "npc_veteran",
          "text": "We don't talk about the diagonal walk."
        },
        {
          "speaker": "npc_farmer",
          "text": "I tried it once. They found my body in a fence."
        }
      ]
    },
    {
      "id": "dt_bathroom",
      "category": "needs",
      "speakers": [
        "npc_humiliated",
        "npc_logician"
      ],
      "lines": [
        {
          "speaker": "npc_humiliated",
          "text": "I peed myself because someone was using the bathroom."
        },
        {
          "speaker": "npc_logician",
          "text": "We have four bathrooms."
        },
        {
          "speaker": "npc_humiliated",
          "text": "It was the principle of the thing."
        }
      ]
    },
    {
      "id": "dt_bed",
      "category": "needs",
      "speakers": [
        "npc_floor_sleeper",
        "npc_pragmatist"
      ],
      "lines": [
        {
          "speaker": "npc_floor_sleeper",
          "text": "Slept on the floor next to a $3000 bed because someone claimed it 0.4 seconds before me."
        },
        {
          "speaker": "npc_pragmatist",
          "text": "You could've just... asked them to move?"
        },
        {
          "speaker": "npc_floor_sleeper",
          "text": "And admit defeat? I have standards."
        }
      ]
    },
    {
      "id": "dt_potato",
      "category": "needs",
      "speakers": [
        "npc_hungry",
        "npc_cook"
      ],
      "lines": [
        {
          "speaker": "npc_hungry",
          "text": "Ate raw potatoes for 3 days because the stove was slightly too far from the fridge."
        },
        {
          "speaker": "npc_cook",
          "text": "Slightly?"
        },
        {
          "speaker": "npc_hungry",
          "text": "Four tiles. Might as well be the moon."
        }
      ]
    },
    {
      "id": "dt_greg",
      "category": "social",
      "speakers": [
        "npc_chicken_friend",
        "npc_judgmental"
      ],
      "lines": [
        {
          "speaker": "npc_chicken_friend",
          "text": "My best friend is a chicken. His name is Greg."
        },
        {
          "speaker": "npc_judgmental",
          "text": "You named a chicken Greg?"
        },
        {
          "speaker": "npc_chicken_friend",
          "text": "He named himself. I just respected his choice."
        }
      ]
    },
    {
      "id": "dt_party",
      "category": "social",
      "speakers": [
        "npc_host",
        "npc_sympathetic"
      ],
      "lines": [
        {
          "speaker": "npc_host",
          "text": "Threw a party. Nobody came. The cake rotted."
        },
        {
          "speaker": "npc_sympathetic",
          "text": "That's depressing."
        },
        {
          "speaker": "npc_host",
          "text": "I ate it anyway. 5/10, would grief again."
        }
      ]
    },
    {
      "id": "dt_seam",
      "category": "existential",
      "speakers": [
        "npc_aware",
        "npc_denier"
      ],
      "lines": [
        {
          "speaker": "npc_aware",
          "text": "Pretty sure I saw a loading seam in the mountains yesterday."
        },
        {
          "speaker": "npc_denier",
          "text": "You should report that."
        },
        {
          "speaker": "npc_aware",
          "text": "I pretended I didn't. We all pretend."
        }
      ]
    },
    {
      "id": "dt_toast",
      "category": "chaos",
      "speakers": [
        "npc_arsonist",
        "npc_confused"
      ],
      "lines": [
        {
          "speaker": "npc_arsonist",
          "text": "Started a fire trying to make toast."
        },
        {
          "speaker": "npc_confused",
          "text": "The bread was already toasted?"
        },
        {
          "speaker": "npc_arsonist",
          "text": "I was just holding it near the stove for moral support."
        }
      ]
    },
    {
      "id": "dt_ladder",
      "category": "chaos",
      "speakers": [
        "npc_builder",
        "npc_concerned"
      ],
      "lines": [
        {
          "speaker": "npc_builder",
          "text": "Built a ladder to nowhere. It goes up. It does not come down."
        },
        {
          "speaker": "npc_concerned",
          "text": "Why?"
        },
        {
          "speaker": "npc_builder",
          "text": "I live there now. Send sandwiches."
        }
      ]
    },
    {
      "id": "dt_indoor_weather",
      "category": "environment",
      "speakers": [
        "npc_damp",
        "npc_fixer"
      ],
      "lines": [
        {
          "speaker": "npc_damp",
          "text": "It's raining inside my house again."
        },
        {
          "speaker": "npc_fixer",
          "text": "Have you tried fixing the roof?"
        },
        {
          "speaker": "npc_damp",
          "text": "It is simply my indoor weather now. I do not question it."
        }
      ]
    },
    {
      "id": "dt_tornado",
      "category": "environment",
      "speakers": [
        "npc_calm",
        "npc_panicker"
      ],
      "lines": [
        {
          "speaker": "npc_calm",
          "text": "Saw a tornado coming. Made a sandwich instead."
        },
        {
          "speaker": "npc_panicker",
          "text": "You didn't go to the shelter?"
        },
        {
          "speaker": "npc_calm",
          "text": "It was a really good sandwich."
        }
      ]
    },
    {
      "id": "dt_shirts",
      "category": "existential",
      "speakers": [
        "npc_hoarder",
        "npc_minimalist"
      ],
      "lines": [
        {
          "speaker": "npc_hoarder",
          "text": "I have 47 identical shirts in my inventory."
        },
        {
          "speaker": "npc_minimalist",
          "text": "Why?"
        },
        {
          "speaker": "npc_hoarder",
          "text": "I will defend each one with my life. Do not test me."
        }
      ]
    },
    {
      "id": "dt_friendship",
      "category": "social",
      "speakers": [
        "npc_invested",
        "npc_cynical"
      ],
      "lines": [
        {
          "speaker": "npc_invested",
          "text": "Spent 6 hours building a friendship with someone."
        },
        {
          "speaker": "npc_cynical",
          "text": "That's nice."
        },
        {
          "speaker": "npc_invested",
          "text": "We're both scheduled to leave the map tomorrow. I want a refund."
        }
      ]
    },
    {
      "id": "dt_cow",
      "category": "chaos",
      "speakers": [
        "npc_puncher",
        "npc_hr"
      ],
      "lines": [
        {
          "speaker": "npc_puncher",
          "text": "Accidentally punched a cow while trying to pet it."
        },
        {
          "speaker": "npc_hr",
          "text": "Is the cow okay?"
        },
        {
          "speaker": "npc_puncher",
          "text": "The cow filed a complaint. HR is involved."
        }
      ]
    },
    {
      "id": "dt_doorframe",
      "category": "chaos",
      "speakers": [
        "npc_traumatized",
        "npc_curious"
      ],
      "lines": [
        {
          "speaker": "npc_traumatized",
          "text": "Called in sick because I got stuck in a doorframe."
        },
        {
          "speaker": "npc_curious",
          "text": "With who?"
        },
        {
          "speaker": "npc_traumatized",
          "text": "Two other people tried to walk through at the same time. It was traumatic."
        }
      ]
    },
    {
      "id": "dt_personality",
      "category": "existential",
      "speakers": [
        "npc_wind",
        "npc_shallow"
      ],
      "lines": [
        {
          "speaker": "npc_wind",
          "text": "My entire personality is 'Likes Wind.'"
        },
        {
          "speaker": "npc_shallow",
          "text": "That's... it?"
        },
        {
          "speaker": "npc_wind",
          "text": "This is all I am. I have accepted it."
        }
      ]
    },
    {
      "id": "dt_berries",
      "category": "needs",
      "speakers": [
        "npc_dead",
        "npc_alive"
      ],
      "lines": [
        {
          "speaker": "npc_dead",
          "text": "Died of starvation surrounded by berries."
        },
        {
          "speaker": "npc_alive",
          "text": "Why didn't you eat them?"
        },
        {
          "speaker": "npc_dead",
          "text": "I forgot I could eat them without putting them in a crate first. Don't look at me."
        }
      ]
    },
    {
      "id": "dt_stare",
      "category": "existential",
      "speakers": [
        "npc_thinker",
        "npc_player_proxy"
      ],
      "lines": [
        {
          "speaker": "npc_thinker",
          "text": "Sometimes I stop in the middle of the road and stare at the sky."
        },
        {
          "speaker": "npc_player_proxy",
          "text": "Are you broken?"
        },
        {
          "speaker": "npc_thinker",
          "text": "I'm just thinking. The player probably thinks I'm broken too."
        }
      ]
    },
    {
      "id": "dt_well",
      "category": "chaos",
      "speakers": [
        "npc_fallen",
        "npc_nurse"
      ],
      "lines": [
        {
          "speaker": "npc_fallen",
          "text": "Fell down a well. Not an important well. Just a decorative one."
        },
        {
          "speaker": "npc_nurse",
          "text": "Are you hurt?"
        },
        {
          "speaker": "npc_fallen",
          "text": "The shame is worse than the injuries."
        }
      ]
    },
