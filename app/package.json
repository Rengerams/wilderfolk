{
  "name": "wilderfolk",
  "private": true,
  "version": "0.4.2",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run && tsc -p tsconfig.vitest.json --noEmit",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview",
    "sim": "node scripts/sim-cli.mjs",
    "bench": "node scripts/benchmark-gate.mjs",
    "dup": "jscpd src --min-lines 8 --min-tokens 60 --format typescript,tsx,javascript --ignore \"**/test/**,**/*.test.ts,**/data/**\""
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jscpd": "^4.2.5",
    "kimi-plugin-inspect-react": "^1.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  }
}
